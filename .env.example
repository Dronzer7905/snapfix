# Snapfix Environment Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR KEYS
# DO NOT COMMIT .env TO VERSION CONTROL

# [LLM Providers]
# Get your Google Gemini key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# [Server]
SNAPFIX_PORT=7842
SNAPFIX_HOST=127.0.0.1
